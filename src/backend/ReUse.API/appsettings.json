{
  "ConnectionStrings": {
    "pgsql": ""
  },
  "Jwt": {
    "Issuer": "",
    "Audience": "",
    "Lifetime": 30,
    "SigningKey": ""
  },
  "RefreshToken": {
    "Lifetime": 15
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft.AspNetCore": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      } 
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
