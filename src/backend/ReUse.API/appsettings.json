      "ApplicationName": "ReUse"
    }
  },
  "ADMIN": {
    "FULLNAME" : "",
    "USERNAME": "",
    "EMAIL" : "",
    "PASSWORD" : ""
  },
  "AllowedHosts": "*"
}
